{
  "name": "gulp-analysis-site",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:trajectories": "sh scripts/build-trajectories-parquet.sh",
    "r2:upload-wasm": "wrangler r2 object put gulp-analysis-data/duckdb-mvp.wasm --remote --file=node_modules/@duckdb/duckdb-wasm/dist/duckdb-mvp.wasm --content-type=application/wasm",
    "pages:deploy": "pnpm build && wrangler pages deploy dist --project-name=gulp-analysis-site",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@duckdb/duckdb-wasm": "1.33.1-dev45.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
